# Local dev: absolute path to Firebase service account JSON (do not commit the key file)
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your-service-account.json

# Production / Vercel: set this in the host dashboard (full JSON as one line), not the path above
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional: Firestore emulator (no key file needed)
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
# FIREBASE_PROJECT_ID=demo-hack
