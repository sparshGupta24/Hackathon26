generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum TimerStatus {
  idle
  running
  ended
}

model Team {
  id        String   @id @default(cuid())
  name      String
  progress  Int      @default(0)
  createdAt DateTime @default(now())
  players   Player[]
  livery    Livery?
}

model RaceUpdate {
  id          Int      @id @default(1)
  teamId      String?
  teamName    String   @default("Race Control")
  message     String
  delta       Int      @default(0)
  accentColor String   @default("#FFFFFF")
  updatedAt   DateTime @updatedAt
}

model Player {
  id     String @id @default(cuid())
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId String
  name   String
  slot   Int

  @@unique([teamId, slot])
}

model Livery {
  id             String @id @default(cuid())
  team           Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId         String @unique
  preset         String
  primaryColor   String
  secondaryColor String
  tertiaryColor  String @default("#8D99AE")
  carNumber      Int
}

model EventTimer {
  id              Int         @id @default(1)
  status          TimerStatus @default(idle)
  startedAt       DateTime?
  baseDurationSec Int         @default(60)
  extendedSec     Int         @default(0)
  updatedAt       DateTime    @updatedAt
}
